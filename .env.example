NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
PROJECT_SLUG=rest-api-template

DB_HOST=mysql
DB_PORT=3306
DB_NAME=template_db
DB_USER=template_user
DB_PASSWORD=template_pass
DB_LOGGING=false

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=template_db
MYSQL_USER=template_user
MYSQL_PASSWORD=template_pass

JWT_ACCESS_SECRET=change_this_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:3000,http://localhost:5173

LOG_LEVEL=debug
LOG_DIR=logs

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
TOKEN_BLACKLIST_CLEANUP_INTERVAL_MS=3600000
ALLOW_NON_STANDARD_TLDS=true
TRUST_PROXY_HOPS=0
ENABLE_PUBLIC_DOCS=true

ADMIN_EMAIL=admin@template.local
ADMIN_PASSWORD=Admin123!

PMA_HOST=mysql
PMA_PORT=3306
PMA_USER=template_user
PMA_PASSWORD=template_pass
